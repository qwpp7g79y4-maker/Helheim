// Helheim Dictionaries Test
print "--- DICTIONARY TEST ---";

zet persoon = {"naam": "Pieter", "rol": "System Architect", "level": 99};
print("Volledige persoon: $persoon");

zet naam = persoon["naam"];
print "Naam van persoon is: $naam";

zet level = persoon["level"];
print "Level is: $level";

functie begroet met n {
    print "Hallo $n, welkom in Helheim!";
}

roep_aan begroet $naam;
