print "=== TEST TEKST MANIPULATIE ===";

zet ruwe_tekst = "  Helheim, is, een, systeem  ";
zet getrimd = roep_aan trim $ruwe_tekst;
print "Getrimd: '$getrimd'";

zet upper = roep_aan hoofdletters $getrimd;
print "Hoofdletters: $upper";

zet gefixt = roep_aan vervang $upper "SYSTEEM" "TAAL";
print "Vervangen: $gefixt";

zet array = roep_aan splits $gefixt ",";
print "Gesplitst in array: $array";
print "=== EINDE TEST ===";
