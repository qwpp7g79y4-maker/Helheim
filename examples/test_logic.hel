zet succes = waar;

print "--- TEST 1: ALS/ANDERS ---";
als succes == waar dan {
    print "Het werkt!";
} anders {
    print "Dit moet niet printen.";
}

zet succes = onwaar;
als succes == waar dan {
    print "Fout. Dit is onwaar.";
} anders {
    print "Correct! De 'anders' branch is uitgevoerd.";
}

print "--- TEST 2: PROBEER/VANG ---";
probeer {
    print "Ik probeer een netwerkverbinding te openen...";
    gooi "Netwerk Fataal! Verbinding verbroken.";
} vang {
    print "Fout netjes afgevangen in de VANG branch! System is safe.";
}

print "Einde script. Overleefd!";
