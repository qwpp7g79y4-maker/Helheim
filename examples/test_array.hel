zet FRUIT = ["Apple", "Banaan", "Kersen"];
zet INFO = {"versie": "3.0", "naam": "Helheim"};
zet EERSTE = FRUIT[0];
zet NAAM = INFO["naam"];

print ">>> START ARRAY TEST <<<";
print "Eerste fruit in de lijst:";
print EERSTE;
print "Software Naam uit Dictionary:";
print NAAM;

print "--- ITERATIE START ---";
voor elke item in FRUIT {
    print "Ik iterereer over: ";
    print item;
}

print ">>> EIND ARRAY TEST <<<";
