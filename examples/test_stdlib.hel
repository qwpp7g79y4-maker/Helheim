zet HersenSpikes = (1, 0, 1, 1);
print "Originele spikes: " $HersenSpikes;

zet Len = lengte(HersenSpikes);
print "Aantal spikes: " $Len;

print "Voeg een nieuwe spike toe (0)...";
roep_aan voeg_toe HersenSpikes 0;

print "Spikes na toevoegen: " $HersenSpikes;
zet NieuweLen = lengte(HersenSpikes);
print "Nieuwe lengte: " $NieuweLen;

print "Verwijder spike op index 1...";
roep_aan verwijder HersenSpikes 1;

print "Spikes na verwijderen: " $HersenSpikes;
