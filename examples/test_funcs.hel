functie tel_op met a b {
    zet res = a + b;
    geef_terug res;
}

zet X = roep_aan tel_op 15 25;

print "We hebben de functie 'tel_op 15 25' aangeroepen.";
print "De teruggegeven waarde is:";
print X;

functie groet met persoon {
    print "Gegroet, ";
    print persoon;
}

print "---";
roep_aan groet "Architect";
