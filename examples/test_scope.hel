zet X = 10;
print "Globaal: " $X;

functie DoeIets met X {
    print "In Functie (Parameter): " $X;
    zet X = 99;
    print "In Functie (Gewijzigd): " $X;
    zet Lokaal = "Geheim";
    print Lokaal;
}

print "Voor Roep Aan: " $X;
roep_aan DoeIets 42;
print "Na Roep Aan (Globaal): " $X;
print "Bestaat Lokaal? " $Lokaal;
