// test_cpu_benchmark.hel
// Dit forceert een gigantische matrix berekening puur via de CPU (Inferno Mode)
// en vergelijkt dit met Python's CPU snelheid.

zet dim = 2048
druk_af("Starten van CPU Benchmark (Helheim Inferno) -> ", dim, "x", dim)

// We roepen inferno work aan om de CPU cores vol te blazen via Rayon
inferno work dim

druk_af("CPU Benchmark Voltooid!")
