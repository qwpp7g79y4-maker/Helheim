print "Welkom in Helheim.";
print "We gaan nu de Hel-modus in (CUDA C++ compilatie op de achtergrond).";

hel {
    extern "C" __global__ void custom_kernel(float* data) {
        int idx = blockIdx.x * blockDim.x + threadIdx.x;
        if (idx < 1024) {
            data[idx] = data[idx] * 666.0f + 1.0f;
        }
    }
}

print "We zijn terug in de veilige omgeving. De code was succesvol gelanceerd op de GPU.";
