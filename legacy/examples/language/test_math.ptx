.version 8.0
.target sm_80
.address_size 64

.visible .entry hel_lowered (
    .param .u64 result_ptr
) {
    .reg .b32 %r<32>;
    .reg .b64 %rd<16>;
    .reg .f32 %f<32>;
    .reg .pred %p<16>;

    ld.param.u64 %rd1, [result_ptr];
    mov.f32 %f0, 0f40490fd0; // Float(3.14159)
    // Genegeerd in PTX: FunctionDef { name: "is_even", params: ["(", "n", ")"], body: Block { statements: [Return { value: Some(Op { left: Op { left: VarGet { name: "n" }, op: "%", right: Literal(Int(2)) }, op: "==", right: Literal(Int(0)) }) }] } }
    mov.u32 %r2, 10;
    mov.u32 %r3, 5;
    mov.u32 %r4, 2;
    mul.lo.u32 %r5, %r3, %r4;
    add.u32 %r6, %r2, %r5;
    // Genegeerd in PTX: Print { message: "x" }
    ret;
}
    ret;
}