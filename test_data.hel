print "=== TEST DATA STRUCTUREN ===";

zet lijst = [1, 2, 3, 4];
roep_aan voeg_toe lijst 5;
print "Mijn lijst na toevoegen is: $lijst";

zet obj = {"speler": "Speler 1", "score": 9000};
zet de_score = roep_aan sleutel $obj "score";
print "De speler score is: $de_score";

zet de_speler = roep_aan sleutel $obj "speler";
print "De naam van de speler is: $de_speler";

zet eerste_item = roep_aan sleutel $lijst 0;
print "Het eerste item in de lijst is: $eerste_item";

print "=== EINDE TEST ===";
